---
import Base from "../layouts/Base.astro";

const areas = [
  ["1", "Risikoanalyse & IT-Sicherheitskonzepte"],
  ["2", "Bewältigung von Sicherheitsvorfällen"],
  ["3", "Aufrechterhaltung des Betriebs (BCM)"],
  ["4", "Sicherheit der Lieferkette"],
  ["5", "Sicherheit bei Erwerb, Entwicklung & Wartung"],
  ["6", "Bewertung der Wirksamkeit"],
  ["7", "Grundlegende Schulungen & Sensibilisierung"],
  ["8", "Kryptographie"],
  ["9", "Personalsicherheit, Zugriffskontrolle & IKT"],
  ["10", "MFA & gesicherte Kommunikation"],
];

const features = [
  ["Rechtsbezug pro Befund", "Jedes Finding zitiert wörtlich §30 Abs. 2 BSIG und den passenden ISO-27001:2022-Control — die Sprache, die Ihr Auditor spricht."],
  ["Strikt read-only", "Die Engine hat keinerlei Schreibrechte. nis2scan liest Ihre Cloud-Konfiguration, es verändert nie eine Ressource."],
  ["Positivnachweise", "Auch was in Ordnung ist, wird dokumentiert — mit maschinenlesbarem Beleg. Für ein Audit zählt der Nachweis, nicht nur der Mangel."],
  ["Fail-safe", "Was nicht geprüft werden konnte, wird als Fehler gemeldet — niemals als „bestanden“. Das Tool behauptet nie mehr, als es geprüft hat."],
  ["Attestierungs-Checkliste", "Was ein Scanner prinzipiell nicht sehen kann (Prozesse, Schulungen, Verantwortlichkeiten), wird als Checkliste an Sie übergeben."],
  ["Permissions-Generator", "nis2scan erzeugt die exakte Least-Privilege-Leseberechtigung selbst — als IAM-Policy oder Azure-RBAC-Rolle, auf Wunsch als Terraform."],
];
---

<Base title="nis2scan — NIS2 (§30 BSIG) Compliance-Scanner für AWS & Azure">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">Open Source · Apache 2.0 · Python</p>
      <h1>Prüfen Sie Ihre Cloud gegen §30 BSIG — mit Rechtsbezug in jedem Befund.</h1>
      <p class="lede">
        Seit Dezember 2025 verpflichtet das NIS2-Umsetzungsgesetz rund 30.000
        Unternehmen zu zehn konkreten Sicherheitsmaßnahmen. nis2scan prüft Ihre
        AWS- und Azure-Umgebung automatisiert gegen genau diese Maßnahmen —
        read-only, auditfähig, kostenlos.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="https://github.com/VVulpe/nis2scan#installation" rel="noopener">Loslegen in 5 Minuten</a>
        <a class="btn btn-ghost" href="#recht">Wie der Rechtsbezug funktioniert</a>
      </div>
      <div class="codeblock hero-code">
        <span class="c"># installieren (Python 3.12+)</span><br />
        pip install nis2scan<br /><br />
        <span class="c"># scannen — Ergebnis auf Deutsch, mit §30-Zitaten</span><br />
        nis2scan scan --provider aws --region eu-central-1
      </div>
      <p class="hero-note">
        <span class="badge">AWS</span> <span class="badge">Azure</span>
        <span class="badge">GCP (experimentell)</span>
        · 154 Checks über alle 10 §30-Bereiche
      </p>
    </div>
  </section>

  <!-- Problem framing -->
  <section class="section band">
    <div class="container">
      <div class="grid cols-3">
        <div>
          <div class="stat">§30</div>
          <p>zehn gesetzlich verpflichtende Risikomanagement-Maßnahmen — ohne Übergangsfrist.</p>
        </div>
        <div>
          <div class="stat">~30.000</div>
          <p>betroffene Einrichtungen in Deutschland (besonders wichtige & wichtige Einrichtungen, §28 BSIG).</p>
        </div>
        <div>
          <div class="stat">§38</div>
          <p>persönliche Verantwortung der Geschäftsleitung für das Risikomanagement.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="funktionen">
    <div class="container">
      <p class="eyebrow">Was nis2scan anders macht</p>
      <h2>Ein Scanner, der die Sprache des Audits spricht.</h2>
      <div class="grid cols-3" style="margin-top:2rem">
        {features.map(([t, d]) => (
          <div class="card">
            <h3>{t}</h3>
            <p>{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Rechtsbezug -->
  <section class="section band" id="recht">
    <div class="container recht-grid">
      <div>
        <p class="eyebrow">Der Unterschied</p>
        <h2>Nicht nur „Fehlkonfiguration“ — sondern welcher Paragraf.</h2>
        <p class="lede" style="margin-bottom:1.25rem">
          Jeder Rechtsbezug hat ein dokumentiertes Vier-Augen-Review gegen den
          Gesetzestext durchlaufen; das Protokoll liegt offen im Repository.
          Das Mapping §30 BSIG ↔ ISO 27001 ist Teil der freien Version.
        </p>
        <a class="btn btn-ghost" href="https://github.com/VVulpe/nis2scan/tree/main/docs" rel="noopener">Mapping & Review-Protokoll ansehen</a>
      </div>
      <div class="finding">
        <div class="finding-head">
          <span class="sev">HOCH</span>
          <span>AWS-NR8-001 · S3 Default Encryption</span>
        </div>
        <dl>
          <dt>Rechtsgrundlage</dt>
          <dd>§30 Abs. 2 Nr. 8 BSIG — „Konzepte und Verfahren für den Einsatz von Kryptografie und Verschlüsselung“.</dd>
          <dt>ISO 27001:2022</dt>
          <dd>A.8.24 Nutzung von Kryptografie</dd>
          <dt>Behebung</dt>
          <dd>Standard-Verschlüsselung (SSE-KMS) für den Bucket aktivieren.</dd>
        </dl>
      </div>
    </div>
  </section>

  <!-- §30 areas -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Vollständige Abdeckung</p>
      <h2>Alle zehn Maßnahmen des §30 Abs. 2 BSIG.</h2>
      <div class="areas" style="margin-top:1.75rem">
        {areas.map(([nr, name]) => (
          <div class="area">
            <span class="area-nr">Nr. {nr}</span>
            <span class="area-name">{name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section band">
    <div class="container cta">
      <h2>In fünf Minuten wissen, wo Sie stehen.</h2>
      <p class="lede" style="margin:0 auto 1.5rem">
        Kostenlos und quelloffen. Point-and-scan mit read-only-Zugang —
        der auditfähige Bericht kommt auf Deutsch.
      </p>
      <div class="hero-cta" style="justify-content:center">
        <a class="btn btn-primary" href="https://github.com/VVulpe/nis2scan#installation" rel="noopener">pip install nis2scan</a>
        <a class="btn btn-ghost" href="https://github.com/VVulpe/nis2scan" rel="noopener">Auf GitHub ansehen</a>
      </div>
    </div>
  </section>

  <style>
    .hero { padding: clamp(3rem, 8vw, 5.5rem) 0 clamp(2rem, 5vw, 3.5rem); }
    .hero-inner { max-width: 820px; }
    .hero h1 { margin: 0 0 1.1rem; }
    .hero-cta { display: flex; gap: 0.85rem; flex-wrap: wrap; margin: 1.75rem 0; }
    .hero-code { margin-top: 1.5rem; max-width: 640px; }
    .hero-note { margin-top: 1.1rem; color: var(--slate); font-size: 0.95rem; display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap; }
    .band { background: var(--paper); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .stat { font-size: 2.5rem; font-weight: 800; color: var(--navy-800); letter-spacing: -0.02em; }
    .recht-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center; }
    @media (max-width: 900px) { .recht-grid { grid-template-columns: 1fr; } }
    .finding { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: 0 10px 30px rgba(15,23,42,.06); }
    .finding-head { display: flex; align-items: center; gap: 0.75rem; background: var(--navy-900); color: #e2e8f0; padding: 0.9rem 1.2rem; font-family: var(--mono); font-size: 0.9rem; }
    .sev { background: var(--accent); color: #1a1206; font-weight: 700; border-radius: 6px; padding: 0.1rem 0.5rem; font-size: 0.78rem; }
    .finding dl { margin: 0; padding: 1.2rem 1.4rem; }
    .finding dt { font-weight: 700; color: var(--navy-800); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.04em; margin-top: 0.9rem; }
    .finding dt:first-child { margin-top: 0; }
    .finding dd { margin: 0.25rem 0 0; color: var(--ink); font-size: 0.98rem; }
    .areas { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    @media (max-width: 720px) { .areas { grid-template-columns: 1fr; } }
    .area { display: flex; align-items: baseline; gap: 0.75rem; padding: 0.8rem 1rem; border: 1px solid var(--border); border-radius: 10px; background: #fff; }
    .area-nr { font-family: var(--mono); font-weight: 700; color: var(--accent-600); font-size: 0.85rem; white-space: nowrap; }
    .area-name { color: var(--ink); font-size: 0.98rem; }
    .cta { text-align: center; max-width: 640px; margin: 0 auto; }
  </style>
</Base>
