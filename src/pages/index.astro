---
import Base from "../layouts/Base.astro";

const areas = [
  ["1", "Risikoanalyse & IT-Sicherheitskonzepte"],
  ["2", "Bewältigung von Sicherheitsvorfällen"],
  ["3", "Aufrechterhaltung des Betriebs (BCM)"],
  ["4", "Sicherheit der Lieferkette"],
  ["5", "Sicherheit bei Erwerb, Entwicklung & Wartung"],
  ["6", "Bewertung der Wirksamkeit"],
  ["7", "Grundlegende Schulungen & Sensibilisierung"],
  ["8", "Kryptographie"],
  ["9", "Personalsicherheit, Zugriffskontrolle & IKT"],
  ["10", "MFA & gesicherte Kommunikation"],
];

const icons = {
  law: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M5 7l7-4 7 4M3.5 14a2.5 2.5 0 0 0 5 0L6 8.5 3.5 14ZM15.5 14a2.5 2.5 0 0 0 5 0L18 8.5 15.5 14ZM8 21h8"/></svg>`,
  eye: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"/><circle cx="12" cy="12" r="2.5"/></svg>`,
  check: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m8.5 12.5 2.5 2.5 4.5-5.5"/></svg>`,
  alert: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4 2.5 20h19L12 4Z"/><path d="M12 10v4M12 17.2v.3"/></svg>`,
  list: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3.5" width="14" height="17" rx="2"/><path d="M9 8h6M9 12h6M9 16h4"/></svg>`,
  key: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="8.5" cy="12" r="4"/><path d="M12.5 12H21m-3 0v3.5M15.5 12v2.5"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 5 6v5c0 4.5 3 8 7 10 4-2 7-5.5 7-10V6l-7-3Z"/><path d="m9 12 2 2 4-4.5"/></svg>`,
};

const features = [
  [icons.law, "Rechtsbezug pro Befund", "Jedes Finding zitiert wörtlich §30 Abs. 2 BSIG und den passenden ISO-27001:2022-Control — die Sprache, die Ihr Auditor spricht."],
  [icons.eye, "Strikt read-only", "Die Engine hat keinerlei Schreibrechte. nis2scan liest Ihre Cloud-Konfiguration, es verändert nie eine Ressource."],
  [icons.check, "Positivnachweise", "Auch was in Ordnung ist, wird dokumentiert — mit maschinenlesbarem Beleg. Für ein Audit zählt der Nachweis, nicht nur der Mangel."],
  [icons.alert, "Fail-safe", "Was nicht geprüft werden konnte, wird als Fehler gemeldet — niemals als „bestanden“. Das Tool behauptet nie mehr, als es geprüft hat."],
  [icons.list, "Attestierungs-Checkliste", "Was ein Scanner prinzipiell nicht sehen kann (Prozesse, Schulungen, Verantwortlichkeiten), wird als Checkliste an Sie übergeben."],
  [icons.key, "Permissions-Generator", "nis2scan erzeugt die exakte Least-Privilege-Leseberechtigung selbst — als IAM-Policy oder Azure-RBAC-Rolle, auf Wunsch als Terraform."],
];
---

<Base title="nis2scan — NIS2 (§30 BSIG) Compliance-Scanner für AWS & Azure">
  <!-- Hero (dunkel) -->
  <section class="hero-dark">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Open Source · Apache 2.0 · Made in Germany</p>
        <h1>Ihre Cloud. Der §30 BSIG.<br /><span class="accent-word">Ein Scan.</span></h1>
        <p class="lede">
          Das NIS2-Umsetzungsgesetz verpflichtet rund 30.000 Unternehmen zu zehn
          konkreten Sicherheitsmaßnahmen — ohne Übergangsfrist. nis2scan prüft
          AWS &amp; Azure dagegen und liefert den auditfähigen Bericht auf
          Deutsch, mit Gesetzeszitat in jedem Befund.
        </p>
        <div class="hero-cta">
          <a class="btn btn-amber" href="https://github.com/VVulpe/nis2scan#installation" rel="noopener">Loslegen in 5 Minuten</a>
          <a class="btn btn-outline-light" href="#recht">Wie der Rechtsbezug funktioniert</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="codeblock hero-code">
          <span class="c"># installieren (Python 3.12+)</span><br />
          <span class="g">$</span> pip install nis2scan<br /><br />
          <span class="c"># scannen — read-only</span><br />
          <span class="g">$</span> nis2scan scan --provider aws<br /><br />
          <span class="c">Erfüllungsgrad nach §30 Abs. 2 BSIG:</span><br />
          &nbsp;Nr. 8 Kryptographie&nbsp;&nbsp;&nbsp;<span style="color:#86efac">erfüllt</span><br />
          &nbsp;Nr. 9 Zugriffskontrolle&nbsp;<span style="color:#fbbf24">teilweise</span><br />
          &nbsp;Nr. 3 BCM&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#f87171">nicht erfüllt</span>
        </div>
      </div>
    </div>
    <div class="container">
      <div class="trust-strip">
        <span class="t"><Fragment set:html={icons.shield} /> 154 rechtsgeprüfte Checks</span>
        <span class="t"><Fragment set:html={icons.eye} /> Strikt read-only</span>
        <span class="t"><Fragment set:html={icons.law} /> Vier-Augen-Rechtsreview, offen im Repo</span>
        <span class="t"><Fragment set:html={icons.check} /> Deutsche Audit-Reports</span>
      </div>
    </div>
  </section>

  <!-- Zahlen -->
  <section class="section">
    <div class="container">
      <div class="grid cols-3">
        <div class="stat-card"><div class="stat">§30</div><p>zehn gesetzlich verpflichtende Risikomanagement-Maßnahmen — seit Dezember 2025 in Kraft.</p></div>
        <div class="stat-card"><div class="stat">~30.000</div><p>betroffene Einrichtungen in Deutschland (besonders wichtige &amp; wichtige Einrichtungen, §28 BSIG).</p></div>
        <div class="stat-card"><div class="stat">§38</div><p>Billigungs- und Überwachungspflicht der Geschäftsleitung für das Risikomanagement — samt Schulungspflicht.</p></div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section band" id="funktionen">
    <div class="container">
      <p class="eyebrow">Was nis2scan anders macht</p>
      <h2 class="h-underline">Ein Scanner, der die Sprache des Audits spricht.</h2>
      <div class="grid cols-3" style="margin-top:2.25rem">
        {features.map(([icon, t, d]) => (
          <div class="card">
            <div class="icon-chip"><Fragment set:html={icon} /></div>
            <h3>{t}</h3>
            <p>{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- So funktioniert's -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">In drei Schritten</p>
      <h2 class="h-underline">Vom Zugang zum auditfähigen Bericht.</h2>
      <div class="steps" style="margin-top:2rem">
        <div class="step">
          <h3>Leserechte erzeugen</h3>
          <p><code>nis2scan permissions</code> generiert die minimale
          Least-Privilege-Rolle für Ihre Cloud — als IAM-Policy, Azure-RBAC
          oder fertiges Terraform. Mehr Zugriff bekommt der Scanner nie.</p>
        </div>
        <div class="step">
          <h3>Scannen</h3>
          <p><code>nis2scan scan</code> prüft alle zehn §30-Bereiche
          read-only — lokal von Ihrem Rechner oder aus Ihrer CI. Ihre Daten
          verlassen Ihre Umgebung nicht.</p>
        </div>
        <div class="step">
          <h3>Bericht übergeben</h3>
          <p>Deutscher Bericht mit Erfüllungsgrad je Maßnahme, Gesetzeszitat
          je Befund, Positivnachweisen und Attestierungs-Checkliste — bereit
          für Auditor und Geschäftsleitung.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ehrliche Abdeckung -->
  <section class="section band" id="abdeckung">
    <div class="container cov-grid">
      <div>
        <p class="eyebrow">Ehrliche Grenzen</p>
        <h2 class="h-underline">Was nis2scan abdeckt — und was bewusst nicht.</h2>
        <p class="lede" style="margin-top:1.25rem">
          NIS2 ist mehr als Technik. nis2scan übernimmt den cloud-technisch
          prüfbaren Teil — und benennt den Rest, statt ihn zu verschweigen.
        </p>
      </div>
      <div class="covlist">
        <div class="covline yes"><span class="mark">✓</span>
          <p>§30 Abs. 2 — der cloud-technische Teil aller zehn Maßnahmen
          <small>154 automatisierte Checks für AWS, Azure und GCP</small></p>
        </div>
        <div class="covline yes"><span class="mark">✓</span>
          <p>Organisatorische §30-Pflichten — als Attestierungs-Checkliste
          <small>Richtlinien, Prozesse, Verantwortlichkeiten: strukturiert zur Eigenbestätigung übergeben</small></p>
        </div>
        <div class="covline no"><span class="mark">✕</span>
          <p>§32/§33 — Meldung erheblicher Sicherheitsvorfälle ans BSI
          <small>ein manueller Meldeprozess mit Fristen; kein Scanner kann ihn für Sie ausführen</small></p>
        </div>
        <div class="covline no"><span class="mark">✕</span>
          <p>§38 — Billigung, Überwachung und Schulung der Geschäftsleitung
          <small>persönliche Organpflicht; der Bericht liefert die Entscheidungsgrundlage dafür</small></p>
        </div>
        <div class="covline no"><span class="mark">✕</span>
          <p>§31 — Zusatzpflichten für Betreiber kritischer Anlagen (KRITIS)
          <small>u. a. Systeme zur Angriffserkennung — eigener Pflichtenkreis jenseits des Scans</small></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Rechtsbezug -->
  <section class="section" id="recht">
    <div class="container recht-grid">
      <div>
        <p class="eyebrow">Der Unterschied</p>
        <h2 class="h-underline">Nicht nur „Fehlkonfiguration“ — sondern welcher Paragraf.</h2>
        <p class="lede" style="margin:1.25rem 0">
          Jeder Rechtsbezug hat ein dokumentiertes Vier-Augen-Review gegen den
          Gesetzestext durchlaufen; das Protokoll liegt offen im Repository.
          Das Mapping §30 BSIG ↔ ISO 27001 ist Teil der freien Version.
        </p>
        <a class="btn btn-ghost" href="https://github.com/VVulpe/nis2scan/tree/main/docs" rel="noopener">Mapping &amp; Review-Protokoll ansehen</a>
      </div>
      <div class="finding">
        <div class="finding-head">
          <span class="sev">HOCH</span>
          <span>AWS-NR8-001 · S3 Default Encryption</span>
        </div>
        <dl>
          <dt>Rechtsgrundlage</dt>
          <dd>§30 Abs. 2 Nr. 8 BSIG — „Konzepte und Verfahren für den Einsatz von Kryptografie und Verschlüsselung“.</dd>
          <dt>ISO 27001:2022</dt>
          <dd>A.8.24 Nutzung von Kryptografie</dd>
          <dt>Behebung</dt>
          <dd>Standard-Verschlüsselung (SSE-KMS) für den Bucket aktivieren.</dd>
        </dl>
      </div>
    </div>
  </section>

  <!-- §30 Bereiche -->
  <section class="section band">
    <div class="container">
      <p class="eyebrow">Vollständige Abdeckung</p>
      <h2 class="h-underline">Alle zehn Maßnahmen des §30 Abs. 2 BSIG.</h2>
      <div class="areas" style="margin-top:2rem">
        {areas.map(([nr, name]) => (
          <div class="area">
            <span class="area-nr">Nr. {nr}</span>
            <span class="area-name">{name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width:820px">
      <p class="eyebrow">Häufige Fragen</p>
      <h2 class="h-underline">Kurz beantwortet.</h2>
      <div class="faq" style="margin-top:1.75rem">
        <details>
          <summary>Ist nis2scan Rechtsberatung oder eine Zertifizierung?</summary>
          <p>Nein — bewusst nicht. nis2scan erstellt technische Nachweise und
          Befunde mit belegter Rechtsgrundlage. Die Bewertung Ihrer
          Gesamt-Compliance bleibt bei Ihnen, Ihrem Auditor und ggf. Ihrer
          Rechtsberatung.</p>
        </details>
        <details>
          <summary>Welche Zugriffe braucht der Scanner?</summary>
          <p>Ausschließlich Leserechte — die exakte Minimal-Berechtigung
          erzeugt <code>nis2scan permissions</code> für Sie. Die Engine
          enthält keinerlei Schreiboperationen; das ist im Quellcode
          nachprüfbar.</p>
        </details>
        <details>
          <summary>Was kostet nis2scan?</summary>
          <p>Der Kern ist kostenlos und Open Source (Apache 2.0): alle Checks,
          alle Provider, deutsche Reports, Attestierungs-Checkliste.
          Kostenpflichtige Stufen ergänzen Komfort und Skalierung (u. a.
          PDF-Export, kontinuierliche Scans) — nie die Korrektheit.</p>
        </details>
        <details>
          <summary>Wohin gehen meine Scan-Daten?</summary>
          <p>Nirgendwohin — der CLI-Scan läuft vollständig in Ihrer Umgebung.
          Berichte entstehen lokal; ein Export-Profil pseudonymisiert auf
          Wunsch alle Ressourcen-Bezeichner für die Weitergabe.</p>
        </details>
        <details>
          <summary>Woher kommt der Rechtsbezug der Checks?</summary>
          <p>Jede Zuordnung zu §30 BSIG und ISO 27001:2022 hat ein
          dokumentiertes Vier-Augen-Review gegen den Normtext durchlaufen —
          Mapping und Review-Protokoll liegen offen im Repository.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA (dunkel) -->
  <section class="hero-dark cta-dark">
    <div class="container cta">
      <h2 style="color:#fff">In fünf Minuten wissen, wo Sie stehen.</h2>
      <p class="lede" style="margin:0 auto 1.75rem">
        Kostenlos und quelloffen. Read-only-Zugang genügt — der auditfähige
        Bericht kommt auf Deutsch.
      </p>
      <div class="hero-cta" style="justify-content:center">
        <a class="btn btn-amber" href="https://github.com/VVulpe/nis2scan#installation" rel="noopener">pip install nis2scan</a>
        <a class="btn btn-outline-light" href="https://github.com/VVulpe/nis2scan" rel="noopener">Auf GitHub ansehen</a>
      </div>
    </div>
  </section>

  <style>
    .hero-dark { padding: clamp(3.5rem, 8vw, 5.5rem) 0 0; }
    .hero-grid { display: grid; grid-template-columns: 1.15fr 1fr; gap: 3rem; align-items: center; padding-bottom: clamp(2rem, 5vw, 3rem); }
    @media (max-width: 940px) { .hero-grid { grid-template-columns: 1fr; } }
    .hero-copy h1 { margin: 0 0 1.1rem; }
    .hero-cta { display: flex; gap: 0.85rem; flex-wrap: wrap; margin-top: 1.75rem; }
    .hero-code { box-shadow: 0 24px 60px rgba(0,0,0,.35); border: 1px solid rgba(148,163,184,.25); }
    .stat-card { border: 1px solid var(--border); border-left: 4px solid var(--accent); border-radius: var(--radius); padding: 1.4rem 1.6rem; background: #fff; }
    .stat { font-size: 2.4rem; font-weight: 800; color: var(--navy-800); letter-spacing: -0.02em; }
    .band { background: var(--paper); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .recht-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: center; }
    @media (max-width: 900px) { .recht-grid { grid-template-columns: 1fr; } }
    .finding { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: 0 16px 44px rgba(15,23,42,.10); }
    .finding-head { display: flex; align-items: center; gap: 0.75rem; background: var(--navy-900); color: #e2e8f0; padding: 0.9rem 1.2rem; font-family: var(--mono); font-size: 0.9rem; }
    .sev { background: var(--accent); color: #1a1206; font-weight: 700; border-radius: 6px; padding: 0.1rem 0.5rem; font-size: 0.78rem; }
    .finding dl { margin: 0; padding: 1.2rem 1.4rem; }
    .finding dt { font-weight: 700; color: var(--navy-800); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.04em; margin-top: 0.9rem; }
    .finding dt:first-child { margin-top: 0; }
    .finding dd { margin: 0.25rem 0 0; color: var(--ink); font-size: 0.98rem; }
    .areas { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    @media (max-width: 720px) { .areas { grid-template-columns: 1fr; } }
    .area { display: flex; align-items: baseline; gap: 0.75rem; padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 10px; background: #fff; }
    .area-nr { font-family: var(--mono); font-weight: 700; color: var(--accent-600); font-size: 0.85rem; white-space: nowrap; }
    .area-name { color: var(--ink); font-size: 0.98rem; }
    .cov-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 3rem; align-items: start; }
    @media (max-width: 900px) { .cov-grid { grid-template-columns: 1fr; } }
    .covlist { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: 0.6rem 1.3rem; box-shadow: 0 12px 34px rgba(15,23,42,.06); }
    .cta-dark { padding: clamp(3rem, 7vw, 5rem) 0; }
    .cta { text-align: center; max-width: 640px; margin: 0 auto; }
  </style>
</Base>
