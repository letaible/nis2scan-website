---
import Base from "../../layouts/Base.astro";
---

<Base title="Contact · nis2scan" description="Contact the nis2scan team." lang="en" altUrl="/kontakt/">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1 class="h-underline">Write to us.</h1>
      <p class="lede" style="margin:1.25rem 0 2rem">
        Questions about nis2scan, feedback, or interest in a pilot project?
        We usually reply within two business days.
      </p>

      <div class="contact-card">
        <p class="contact-label">The fastest way to reach us is by email:</p>
        <p class="contact-mail"><a href="mailto:info@letaible.de">info@letaible.de</a></p>
        <div class="contact-actions">
          <a class="btn btn-primary" href="mailto:info@letaible.de?subject=nis2scan%20inquiry">Write an email</a>
          <button class="btn btn-copy" id="copy-mail" type="button">Copy address</button>
        </div>
        <p class="privacy-note">
          Your details are processed solely to handle this request. Details
          in the <a href="/datenschutz/">Privacy Policy (German)</a>.
        </p>
      </div>
    </div>
  </section>

  <script>
    const btn = document.getElementById("copy-mail");
    if (btn) {
      btn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText("info@letaible.de");
          btn.textContent = "Copied ✓";
          setTimeout(() => (btn.textContent = "Copy address"), 2000);
        } catch {
          window.location.href = "mailto:info@letaible.de";
        }
      });
    }
  </script>

  <style>
    .contact-card { border: 1px solid #e2e8f0; border-radius: 14px; padding: 1.75rem 2rem; max-width: 560px; background: #fff; }
    .contact-label { margin: 0 0 0.35rem; color: var(--slate); }
    .contact-mail { margin: 0 0 1.25rem; font-size: 1.4rem; font-weight: 700; }
    .contact-mail a { color: var(--navy, #0b1b34); text-decoration: none; }
    .contact-mail a:hover { text-decoration: underline; }
    .contact-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .btn-copy { background: #fff; border: 1px solid #cbd5e1; color: var(--navy, #0b1b34); cursor: pointer; }
    .privacy-note { font-size: 0.88rem; color: var(--slate); margin: 0; }
  </style>
</Base>
