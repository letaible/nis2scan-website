---
import "../styles/global.css";
const { title, description } = Astro.props;
const desc =
  description ??
  "Open-Source-Scanner für §30 BSIG (NIS2): prüft AWS & Azure gegen die zehn Pflichtmaßnahmen — jeder Befund mit Rechtsgrundlage.";
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="site-head">
      <div class="container head-inner">
        <a href="/" class="brand" aria-label="nis2scan Startseite">
          <span class="brand-mark">§30</span>
          <span class="brand-word">nis2scan</span>
        </a>
        <nav class="nav">
          <a href="/#funktionen">Funktionen</a>
          <a href="/#recht">Rechtsbezug</a>
          <a href="https://github.com/VVulpe/nis2scan" rel="noopener">GitHub</a>
          <a class="btn btn-primary btn-sm" href="https://github.com/VVulpe/nis2scan#installation" rel="noopener">Loslegen</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot foot-dark">
      <div class="container foot-inner">
        <div>
          <span class="brand-word foot-brand">nis2scan</span>
          <p class="foot-note">
            Open Source (Apache 2.0). Ein Produkt der Letaible GmbH.
            Kein Compliance-Zertifikat, keine Rechtsberatung — die technische
            Nachweis-Ebene darunter.
          </p>
        </div>
        <nav class="foot-links">
          <a href="https://github.com/VVulpe/nis2scan" rel="noopener">GitHub</a>
          <a href="https://pypi.org/project/nis2scan/" rel="noopener">PyPI</a>
          <a href="https://letaible.de" rel="noopener">letaible</a>
          <a href="/kontakt/">Kontakt</a>
          <a href="/impressum/">Impressum</a>
          <a href="/datenschutz/">Datenschutz</a>
        </nav>
      </div>
      <div class="container foot-copy">© {year} Letaible GmbH · nis2scan</div>
    </footer>

    <style>
      .site-head {
        position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,.85);
        backdrop-filter: saturate(1.6) blur(8px); border-bottom: 1px solid var(--border);
      }
      .head-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { display: flex; align-items: center; gap: 0.55rem; text-decoration: none; }
      .brand-mark {
        background: var(--navy-800); color: #fff; font-weight: 700;
        border-radius: 8px; padding: 0.15rem 0.45rem; font-size: 0.95rem;
      }
      .brand-word { font-weight: 700; color: var(--navy-900); font-size: 1.1rem; letter-spacing: -0.01em; }
      .nav { display: flex; align-items: center; gap: 1.25rem; }
      .nav a { text-decoration: none; color: var(--slate); font-weight: 500; font-size: 0.95rem; }
      .nav a:hover { color: var(--navy-800); }
      .btn-sm { padding: 0.5rem 0.9rem; font-size: 0.9rem; }
      @media (max-width: 680px) {
        .nav a:not(.btn) { display: none; }
      }
      .site-foot { border-top: 1px solid var(--border); background: var(--paper); margin-top: 4rem; padding: 2.5rem 0 1.5rem; }
      .foot-inner { display: flex; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
      .foot-brand { font-size: 1.1rem; }
      .foot-note { max-width: 46ch; font-size: 0.9rem; margin: 0.4rem 0 0; }
      .foot-links { display: flex; gap: 1.25rem; flex-wrap: wrap; align-items: flex-start; }
      .foot-links a { color: var(--slate); text-decoration: none; font-size: 0.92rem; }
      .foot-links a:hover { color: var(--navy-800); }
      .foot-copy { margin-top: 1.5rem; color: var(--slate-300); font-size: 0.85rem; }
    </style>
  </body>
</html>
