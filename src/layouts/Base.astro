---
import "../styles/global.css";
const { title, description, lang = "de", altUrl } = Astro.props;
const desc =
  description ??
  (lang === "en"
    ? "Open-source scanner for §30 BSIG (the German NIS2 implementation in the BSI Act): checks AWS & Azure against the ten mandatory measures, every finding with its legal basis."
    : "Open-Source-Scanner für §30 BSIG (NIS2): prüft AWS & Azure gegen die zehn Pflichtmaßnahmen, jeder Befund mit Rechtsgrundlage.");
const year = new Date().getFullYear();
const resolvedAltUrl = altUrl ?? (lang === "de" ? "/en/" : "/");
const home = lang === "en" ? "/en/" : "/";
const kontaktHref = lang === "en" ? "/en/contact/" : "/kontakt/";

const t =
  lang === "en"
    ? {
        brandAria: "nis2scan homepage",
        navFeatures: "Features",
        navLegal: "Legal mapping",
        navGithub: "GitHub",
        navCta: "Get started",
        footNote:
          "Open source (Apache 2.0). A product of Letaible GmbH. Not a compliance certificate or legal advice, but the technical evidence layer underneath.",
        footKontakt: "Contact",
        footImpressum: "Imprint (German)",
        footDatenschutz: "Privacy (German)",
      }
    : {
        brandAria: "nis2scan Startseite",
        navFeatures: "Funktionen",
        navLegal: "Rechtsbezug",
        navGithub: "GitHub",
        navCta: "Loslegen",
        footNote:
          "Open Source (Apache 2.0). Ein Produkt der Letaible GmbH. Kein Compliance-Zertifikat und keine Rechtsberatung, sondern die technische Nachweis-Ebene darunter.",
        footKontakt: "Kontakt",
        footImpressum: "Impressum",
        footDatenschutz: "Datenschutz",
      };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      // Strato-Webspace verarbeitet keine .htaccess, daher Client-Redirect auf
      // HTTPS. Vorher ein Probe-Fetch: nur umleiten, wenn TLS wirklich
      // funktioniert (sonst bliebe die Seite bei fehlendem Zertifikat haengen).
      if (location.protocol === "http:" && location.hostname !== "localhost") {
        fetch("https://" + location.host + "/favicon.svg", { mode: "no-cors", cache: "no-store" })
          .then(function () {
            location.replace("https://" + location.host + location.pathname + location.search + location.hash);
          })
          .catch(function () {});
      }
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://nis2scan.de/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header class="site-head">
      <div class="container head-inner">
        <a href={home} class="brand" aria-label={t.brandAria}>
          <span class="brand-mark"><span class="brand-para">§</span>30</span>
          <span class="brand-word">nis2scan</span>
        </a>
        <nav class="nav">
          <a href={`${home}#funktionen`}>{t.navFeatures}</a>
          <a href={`${home}#recht`}>{t.navLegal}</a>
          <a href="https://github.com/letaible/nis2scan" rel="noopener">{t.navGithub}</a>
          <a class="btn btn-primary btn-sm" href="https://github.com/letaible/nis2scan#installation" rel="noopener">{t.navCta}</a>
          <a class="lang-switch" href={resolvedAltUrl}>{lang === "de" ? "EN" : "DE"}</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot foot-dark">
      <div class="container foot-inner">
        <div>
          <span class="brand-word foot-brand">nis2scan</span>
          <p class="foot-note">{t.footNote}</p>
        </div>
        <nav class="foot-links">
          <a href="https://github.com/letaible/nis2scan" rel="noopener">GitHub</a>
          <a href="https://pypi.org/project/nis2scan/" rel="noopener">PyPI</a>
          <a href="https://letaible.de" rel="noopener">letaible</a>
          <a href={kontaktHref}>{t.footKontakt}</a>
          <a href="/impressum/">{t.footImpressum}</a>
          <a href="/datenschutz/">{t.footDatenschutz}</a>
        </nav>
      </div>
      <div class="container foot-copy">© {year} Letaible GmbH · nis2scan</div>
    </footer>

    <style>
      .site-head {
        position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,.85);
        backdrop-filter: saturate(1.6) blur(8px); border-bottom: 1px solid var(--border);
      }
      .head-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
      .brand { display: flex; align-items: center; gap: 0.55rem; text-decoration: none; }
      .brand-mark {
        background: linear-gradient(135deg, #12294d, #0b1b34); color: #fff; font-weight: 700;
        border-radius: 8px; padding: 0.15rem 0.45rem; font-size: 0.95rem;
      }
      .brand-para { color: #f59e0b; }
      .brand-word { font-weight: 700; color: var(--navy-900); font-size: 1.1rem; letter-spacing: -0.01em; }
      .nav { display: flex; align-items: center; gap: 1.25rem; }
      .nav a { text-decoration: none; color: var(--slate); font-weight: 500; font-size: 0.95rem; }
      .nav a:hover { color: var(--navy-800); }
      .nav a.btn { color: #fff; }
      .nav a.btn:hover { color: #fff; }
      .btn-sm { padding: 0.5rem 0.9rem; font-size: 0.9rem; }
      .nav a.lang-switch { border: 1px solid var(--border); border-radius: 8px; padding: 0.25rem 0.55rem; }
      @media (max-width: 680px) {
        .nav a:not(.btn):not(.lang-switch) { display: none; }
      }
      .site-foot { border-top: 1px solid var(--border); background: var(--paper); margin-top: 4rem; padding: 2.5rem 0 1.5rem; }
      .foot-inner { display: flex; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
      .foot-brand { font-size: 1.1rem; }
      .foot-note { max-width: 46ch; font-size: 0.9rem; margin: 0.4rem 0 0; }
      .foot-links { display: flex; gap: 1.25rem; flex-wrap: wrap; align-items: flex-start; }
      .foot-links a { color: var(--slate); text-decoration: none; font-size: 0.92rem; }
      .foot-links a:hover { color: var(--navy-800); }
      .foot-copy { margin-top: 1.5rem; color: var(--slate-300); font-size: 0.85rem; }
    </style>
  </body>
</html>
